# Admin Dashboard Password - Set this to secure your admin panel
ADMIN_PASSWORD=your-secure-password-here

# Resend API Key for Email Notifications (Free tier: 3000 emails/month)
# Sign up at https://resend.com
RESEND_API_KEY=re_placeholder

# Email address to receive contact form and join form submissions
CONTACT_EMAIL=contact@uget.tn

# Cloudinary Image Upload (Free tier: 25GB storage, 25GB bandwidth/month)
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Anthropic API Key for Chatbot (Optional)
ANTHROPIC_API_KEY=sk-ant-placeholder

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
